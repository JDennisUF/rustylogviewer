poll_interval_ms = 1000
max_buffer_lines = 10000
max_line_len = 512
show_timestamps = true
gui_light_mode = false
gui_theme = "default_dark" # default_dark | light | high_contrast | ocean_blue | shades_of_purple | novare | novare_light | dracula | nord | solarized_dark | solarized_light | one_dark
gui_word_wrap = true
gui_font_size = 14.0
case_insensitive_text_filter = true

# Lines matching blacklist patterns are hidden unless they also match a whitelist pattern.
blacklist_regex = [
  #"DEBUG.*",
]
whitelist_regex = [
  #"DEBUG.*important",
]

tracked_files = [
  "/var/log/app.log",
  "/tmp/dev.log",
  "/tmp/app-*.log",
  # Date placeholders are resolved at poll time, so daily rollover works without restarting.
  "/tmp/app_{yyyymmdd}.log",
  # `{today}` tries several common numeric formats for the current date:
  # yyyymmdd, yyyy-mm-dd, yyyy_mm_dd, mmdd, mm-dd, mm_dd, yymmdd, yy-mm-dd, yy_mm_dd
  "/tmp/daily_{today}.log",
]

# Optional per-resolved-file enable state persisted by the GUI.
# These keys refer to concrete file paths, not the raw tracked_files patterns.
tracked_file_enabled = { "/tmp/app-20260426.log" = true, "/tmp/app-0426.log" = false }
