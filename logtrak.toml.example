poll_interval_ms = 1000
max_buffer_lines = 10000
max_line_len = 512
show_timestamps = true
gui_light_mode = false
gui_theme = "default_dark" # default_dark | light | high_contrast | ocean_blue | shades_of_purple | novare | novare_light | dracula | nord | solarized_dark | solarized_light | one_dark
gui_word_wrap = true
gui_font_size = 14.0
case_insensitive_text_filter = true

# Lines matching blacklist patterns are hidden unless they also match a whitelist pattern.
blacklist_regex = [
  #"DEBUG.*",
]
whitelist_regex = [
  #"DEBUG.*important",
]

tracked_files = [
  "/var/log/app.log",
  "/tmp/dev.log",
]
